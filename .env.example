# ============================================================
#  SmartHome Installer - Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#    nano .env
#
#  Any value left blank will be prompted interactively by setup.sh.
#  restore-standalone.sh requires TELEGRAM_* to send alerts.
# ============================================================

# --- Telegram Notifications (used by restore-standalone.sh watchdog) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Tailscale VPN (leave blank to skip) ---
# Generate at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_KEY=

# --- Cloudflare Tunnel (leave blank to skip) ---
# Zero Trust Dashboard -> Networks -> Tunnels -> copy install token
CF_TOKEN=

# --- Home Assistant Location ---
HA_TIMEZONE=Asia/Jerusalem
HA_LATITUDE=31.2529
HA_LONGITUDE=34.7914
HA_ELEVATION=260

# --- MQTT Password (auto-generated if left blank) ---
# A 32-char hex password will be generated automatically during setup.
# Only set this if you need a specific password.
MQTT_PASSWORD=
